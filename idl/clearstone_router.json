    "name": "clearstone_router",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "Clearstone periphery router: base-asset UX for core. Wraps base↔SY mint/redeem around clearstone_core primitives so users never handle raw SY."
  },
