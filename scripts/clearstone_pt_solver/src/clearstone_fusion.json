  "instructions": [
    {
      "name": "cancel",
      "docs": [
        "Maker explicitly voids an outstanding order on-chain. Initializes",
        "(or updates) `OrderState` with `canceled = true` so resolvers can",
        "observe cancellation authoritatively instead of relying on stale",
        "off-chain state."
      ],
